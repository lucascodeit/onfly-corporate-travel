meta {
  name: Change Password
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/profile/password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "current_password": "password",
    "new_password": "newpassword123",
    "new_password_confirmation": "newpassword123"
  }
}
